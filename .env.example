# -----------------------------------------------------------------------------
# MUTUAL FUND FAQ ASSISTANT - DEPLOYMENT CONFIGURATION
# -----------------------------------------------------------------------------

# 1. LLM API KEYS (Add these to GitHub Secrets and Vercel Environment Variables)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 2. FRONTEND CONFIGURATION (Add to Vercel Environment Variables)
# For Vercel deployment, this should be https://your-domain.vercel.app/api/chat
VITE_API_URL=http://localhost:8000/api/chat

# 3. GITHUB ACTIONS SECRETS (Add to GitHub Repository Secrets)
# GH_TOKEN: A Personal Access Token (PAT) with 'repo' scope to allow the scheduler to push data updates
# GROQ_API_KEY: Same as above
# GEMINI_API_KEY: Same as above

# 4. DIRECTORY PATHS (Default values used in production)
CHROMA_DB_PATH=./data/6_chroma_index
SQLITE_DB_PATH=./data/5_structured_facts/facts.db
BANNED_PHRASES_PATH=./phase_5_compliance_validation/5.1_advisory_detection/banned_phrases.json
