{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/$1"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "data/0_raw_html/**,data/1_extracted_facts/**,data/2_normalized_text/**,data/3_chunks/**,data/4_embeddings/**,data/7_audit_logs/**,data/8_query_logs/**,data/9_response_cache/**,data/rollback_backups/**"
    }
  }
}
