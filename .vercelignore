# Exclude all large data subdirectories
data/0_raw_html/
data/2_normalized_text/
data/7_audit_logs/
data/8_query_logs/
data/9_response_cache/
data/rollback_backups/

# Exclude contents of processed data but keep the directory for whitelisting
data/1_extracted_facts/*
data/3_chunks/*
data/4_embeddings/*

# Whitelist ONLY production-critical files
!data/1_extracted_facts/extract_manifest.json
!data/3_chunks/DOC-*_chunks.jsonl
!data/4_embeddings/embeddings.json
!data/5_structured_facts/facts.db

# Other exclusions
node_modules/
venv/
.git/
scratch/
tests/
README.md
SourceWebsites.md
architecture.md
run_ingestion.py
run_pipeline.py
setup_github.py
phase_7_frontend/node_modules/
phase_7_frontend/src/
phase_7_frontend/public/
